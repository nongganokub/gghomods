-- ฟังก์ชันล้าง ESP เมื่อผู้เล่นออก (แก้ปัญหา ESP ค้าง)
local function RemoveESP(p)
    if DrawingObjects[p] then
        for _, obj in pairs(DrawingObjects[p]) do
            obj.Visible = false
            obj:Remove()
        end
        DrawingObjects[p] = nil
    end
end

Players.PlayerRemoving:Connect(RemoveESP)

-- // 2. CROSSHAIR SYSTEM //
local function CreateCrosshair()
    CrosshairLines.H = Drawing.new("Line")
    CrosshairLines.V = Drawing.new("Line")
    for _, l in pairs(CrosshairLines) do
        l.Thickness = 1.5; l.Transparency = 1; l.Visible = false
    end
end
CreateCrosshair()

-- // 3. ESP FUNCTIONS //
local function CreateDrawing(type, properties)
    local obj = Drawing.new(type)
    for i, v in pairs(properties) do obj[i] = v end
    return obj
end

local function GetObjects(p)
    if not DrawingObjects[p] then
        DrawingObjects[p] = {
            Box = CreateDrawing("Square", {Thickness = 1, Filled = false}),
            Tracer = CreateDrawing("Line", {Thickness = 1}),
            HealthBar = CreateDrawing("Line", {Thickness = 2}),
            HealthBG = CreateDrawing("Line", {Thickness = 2, Transparency = 0.5, Color = Color3.new(0,0,0)}),
            NameLabel = CreateDrawing("Text", {Size = 13, Center = true, Outline = true}),
            ItemLabel = CreateDrawing("Text", {Size = 11, Center = true, Outline = true, Color = Color3.fromRGB(255, 200, 0)}),
            DistanceLabel = CreateDrawing("Text", {Size = 11, Center = true, Outline = true})
        }
    end
    return DrawingObjects[p]
end

local function ManageHitbox(char, hum)
    local head = char:FindFirstChild("Head")
    if not head then return end
    if _G.HitboxEnabled and hum.Health > 0 then
        head.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
        head.Transparency = 1; head.CanCollide = false; head.Massless = true
        for _, v in pairs(head:GetChildren()) do
            if v:IsA("Decal") or v:IsA("SpecialMesh") or v:IsA("MeshPart") then
                pcall(function() v.Transparency = 1 end)
                if v:IsA("SpecialMesh") or v:IsA("MeshPart") then v.Scale = Vector3.new(0,0,0) end
            end
        end
    else
        head.Size = Vector3.new(1.2, 1.2, 1.2); head.Transparency = 0
        for _, v in pairs(head:GetChildren()) do
            if v:IsA("Decal") or v:IsA("SpecialMesh") or v:IsA("MeshPart") then
                pcall(function() v.Transparency = 0 end)
                if v:IsA("SpecialMesh") or v:IsA("MeshPart") then v.Scale = Vector3.new(1,1,1) end
            end
        end
    end
end

-- // 4. MAIN RENDER LOOP //
RunService.RenderStepped:Connect(function()
    local Center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    -- เป้ากลางจอ
    if _G.CrosshairEnabled then
        for _, l in pairs(CrosshairLines) do l.Visible = true; l.Color = ChromaColor end
        CrosshairLines.H.From = Center - Vector2.new(10, 0); CrosshairLines.H.To = Center + Vector2.new(10, 0)
        CrosshairLines.V.From = Center - Vector2.new(0, 10); CrosshairLines.V.To = Center + Vector2.new(0, 10)
    else
        for _, l in pairs(CrosshairLines) do l.Visible = false end
    end

    -- ESP Loop
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        
        local char = p.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local obj = GetObjects(p)

        -- เช็คสถานะตัวละคร (ถ้าตายหรือไม่มีตัวตน ให้ซ่อน ESP ทันที)
        if _G.EspEnabled and char and hum and hrp and hum.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            ManageHitbox(char, hum)

            if onScreen then
                local visible = true
                if _G.WallCheck then
                    local res = Camera:GetPartsObscuringTarget({Camera.CFrame.Position, hrp.Position}, {LocalPlayer.Character, char})
                    visible = (#res == 0)
                end
                local col = visible and Color_Visible or Color_Invis
                local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
                local f = 1 / (dist * math.tan(math.rad(Camera.FieldOfView/2))) * 1000
                local w, h = 4.2 * f, 5.8 * f

                obj.Box.Visible = _G.ShowBox
                obj.Box.Size = Vector2.new(w, h); obj.Box.Position = Vector2.new(pos.X - w/2, pos.Y - h/2); obj.Box.Color = col

                if _G.ShowHealth then
                    obj.HealthBar.Visible = true; obj.HealthBG.Visible = true
                    local hpP = hum.Health / hum.MaxHealth
                    obj.HealthBG.From = Vector2.new(pos.X - w/2 - 4, pos.Y + h/2); obj.HealthBG.To = Vector2.new(pos.X - w/2 - 4, pos.Y - h/2)
                    obj.HealthBar.From = Vector2.new(pos.X - w/2 - 4, pos.Y + h/2); obj.HealthBar.To = Vector2.new(pos.X - w/2 - 4, (pos.Y + h/2) - (h * hpP))
                    obj.HealthBar.Color = Color3.fromHSV(hpP * 0.3, 1, 1)
                else obj.HealthBar.Visible = false; obj.HealthBG.Visible = false end

                obj.NameLabel.Visible = true; obj.NameLabel.Position = Vector2.new(pos.X, pos.Y - h/2 - 25); obj.NameLabel.Text = p.DisplayName; obj.NameLabel.Color = col
                
                if _G.ShowItem then
                    local tool = char:FindFirstChildOfClass("Tool")
                    obj.ItemLabel.Visible = true; obj.ItemLabel.Position = Vector2.new(pos.X, pos.Y - h/2 - 12); obj.ItemLabel.Text = tool and tool.Name or "Hands"
                else obj.ItemLabel.Visible = false end

                obj.DistanceLabel.Visible = true; obj.DistanceLabel.Position = Vector2.new(pos.X, pos.Y + h/2 + 5); obj.DistanceLabel.Text = "[" .. math.floor(dist) .. "m]"; obj.DistanceLabel.Color = Color3.new(1,1,1)
                obj.Tracer.Visible = _G.ShowTracer; obj.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); obj.Tracer.To = Vector2.new(pos.X, pos.Y + h/2); obj.Tracer.Color = col
            else
                for _, v in pairs(obj) do v.Visible = false end
            end
        else
            -- ล้างการแสดงผลเมื่อเงื่อนไขไม่ครบ (ตาย หรือ ปิด ESP)
            for _, v in pairs(obj) do v.Visible = false end
        end
    end
end)

